# JWT secret — generate a long random string (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`)
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — SQLite for local dev, PostgreSQL for Railway/production
# Local:  sqlite+aiosqlite:///./app.db
# Railway: postgresql+asyncpg://<user>:<pass>@<host>:<port>/<db>
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000
